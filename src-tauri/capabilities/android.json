{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "android-default",
  "description": "Capabilities for Android",
  "platforms": ["android"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "store:default",
    "log:default",
    "os:default",
    "opener:default",
    "process:default"
  ]
}
